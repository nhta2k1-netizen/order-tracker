# ===== Telegram Bot (bắt buộc cho bot) =====
# Tạo bot: mở @BotFather → /newbot → copy token
TELEGRAM_BOT_TOKEN=

# Tùy chọn: chỉ cho phép chat_id này (để trống = mọi người)
# TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321

# ===== Database =====
# Mặc định: ./data/tracker.db (tự tạo)
DATA_DIR=./data

# ===== Polling thông báo =====
# Khoảng poll mặc định (phút) khi đơn đang vận chuyển
POLL_INTERVAL_MINUTES=10
# Poll nhanh hơn khi đang giao (phút)
POLL_FAST_MINUTES=5
# Poll chậm khi chờ lấy / chưa có status (phút)
POLL_SLOW_MINUTES=30

# ===== API (dùng sau cho Web) =====
PORT=4000
HOST=0.0.0.0
API_BASE_URL=http://localhost:4000

# ===== Web deep-link (nút "Nhận thông báo Telegram") =====
# Username bot không có @, ví dụ: my_order_tracker_bot
TELEGRAM_BOT_USERNAME=

# ===== Zalo Official Account (test free — gói Cơ bản) =====
# Tạo app: https://developers.zalo.me/ → liên kết OA
# Hướng dẫn: HUONG-DAN-ZALO.md
ZALO_APP_ID=
ZALO_APP_SECRET=
# Lấy sau OAuth (access ~1h, refresh ~3 tháng, refresh dùng 1 lần)
ZALO_ACCESS_TOKEN=
ZALO_REFRESH_TOKEN=
# URL public HTTPS cho webhook (cloudflared), vd https://xxx.trycloudflare.com
# ZALO_PUBLIC_BASE_URL=
