{
  "name": "order-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Theo dõi đơn hàng Shopee / TikTok Shop / đa carrier VN — Web + Telegram Bot",
  "workspaces": [
    "apps/*",
    "packages/*"
